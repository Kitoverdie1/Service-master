# Prisma CLI ใช้บรรทัดนี้
DATABASE_URL="mysql://root:123456@127.0.0.1:3306/uph_mem_system"

# ตัวโปรเจกต์ตอนรันจริง (lib/prisma/prisma.ts) ใช้ชุดนี้
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=123456
DATABASE_NAME=uph_mem_system

# NextAuth (อย่างน้อยต้องมี 2 ตัวนี้ ไม่งั้น /api/auth/session 500)
NEXTAUTH_URL=http://10.27.105.214:3000/
AUTH_SECRET=put_random_string_here

# Microsoft Entra (ใส่ของจริงจาก Azure)
AUTH_MICROSOFT_ENTRA_ID_ID=xxxxx
AUTH_MICROSOFT_ENTRA_ID_SECRET=xxxxx
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0